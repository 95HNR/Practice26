generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int    @id @default(autoincrement())
  username      String @unique
  password_hash String
  role          String @default("USER") // "ADMIN" vagy "USER"
}

model Auto {
  rendszam       String  @id
  tipus          String
  statusz        String  @default("ELERHETO") // "ELERHETO" vagy "FOGLALT"
  itp_lejart     String? // Pl. "2026-10-15"
  utado_fizetve  String? // Pl. "2026-12-31"
  szerviz_adatok String? // Szerviztörténet leírása
  utak           Ut[]
}

model Ut {
  id            Int    @id @default(autoincrement())
  sofor_nev     String
  auto_rendszam String
  auto          Auto   @relation(fields: [auto_rendszam], references: [rendszam])
  indulas       String
  erkezes       String
  tavolsag      Float
  koltseg       Float
  fogyasztas    Float
  honap_ev      String // Pl. "2026-07"
  status        String @default("BEERKEZO") // "BEERKEZO", "JOVAHAGYOTT", "ELUTASITOTT"
}