generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password_hash String
  role          String   @default("USER")
}

model Auto {
  rendszam           String    @id
  tipus              String
  statusz            String    @default("ELERHETO")
  itp_lejarat        DateTime?
  biztositas_lejarat DateTime?
  utado_lejarat      DateTime?
  utak               Ut[]
  szervizek          Szerviz[]
}

model Szerviz {
  id            Int      @id @default(autoincrement())
  auto_rendszam String
  datum         DateTime
  leiras        String
  kilometer     Int
  auto          Auto     @relation(fields: [auto_rendszam], references: [rendszam], onDelete: Cascade)
}

model Ut {
  id            Int      @id @default(autoincrement())
  honap_ev      String
  sofor_nev     String
  auto_rendszam String
  indulas       String
  erkezes       String
  tavolsag      Float
  koltseg       Float
  fogyasztas    Float
  status        String   @default("BEERKEZO")
  auto          Auto     @relation(fields: [auto_rendszam], references: [rendszam], onDelete: Cascade)
}
