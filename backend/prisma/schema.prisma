generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int    @id @default(autoincrement())
  username      String @unique
  password_hash String
  role          String @default("USER")
}

model Auto {
  rendszam           String    @id
  tipus              String
  statusz            String    @default("ELERHETO") // ELERHETO, FOGLALT
  itp_lejarat        DateTime? // Dátum formátum
  biztositas_lejarat DateTime?
  utado_lejarat      DateTime?
  szerviz_naplo      String?
  utak               Ut[]
}

model Ut {
  id            Int    @id @default(autoincrement())
  sofor_nev     String
  auto_rendszam String
  auto          Auto   @relation(fields: [auto_rendszam], references: [rendszam])
  indulas       String
  erkezes       String
  tavolsag      Float
  koltseg       Float
  fogyasztas    Float
  honap_ev      String
  status        String @default("BEERKEZO")
}
